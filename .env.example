# ─── Server ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=socialcall_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this
JWT_REFRESH_EXPIRES_IN=30d

# ─── OTP Provider ─────────────────────────────────────────────────────
# Choose one: fast2sms | msg91 | twilio
SMS_PROVIDER=msg91
OTP_EXPIRY_SECONDS=300

# ─── Fast2SMS (Cheapest Indian — ₹0.04/SMS) ───────────────────────────
# Sign up: fast2sms.com → Dev API → copy key
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ─── MSG91 (Best Indian — ₹0.18/SMS) ──────────────────────────────────
# Sign up: msg91.com → API → copy Auth Key + create OTP template
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_TEMPLATE_ID=your_msg91_template_id_here

# ─── Twilio (International fallback) ──────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Razorpay ─────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Firebase (Push Notifications) ───────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ─── Agora RTC (Audio/Video Calls + Live Streaming) ──────────────────────
# Sign up at agora.io → Console → Create Project → copy App ID + Certificate.
# App Certificate is required for token-based auth (enable in project settings).
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# ─── Admin Panel ──────────────────────────────────────────────────────
# Change this to a strong password — used to log into /admin panel
ADMIN_SECRET=change_me_to_a_strong_admin_password

# ─── Platform Config ──────────────────────────────────────────────────
PLATFORM_COMMISSION_PERCENT=35
MIN_WALLET_BALANCE=10
MAX_WALLET_BALANCE=100000
CALL_BILLING_INTERVAL_SECONDS=60

# ─── File Upload ──────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads
